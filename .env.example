# Copy to .env and adjust for local development.
# .env is gitignored; never commit secrets.

# ----- Database -----
# Local SQLite (default). For Postgres: postgresql://user:pass@localhost:5432/wardrobe
# DATABASE_URL=sqlite:///./data/wardrobe.db

# ----- Storage -----
# local = store images under STORAGE_LOCAL_PATH (default: ./data/uploads)
# STORAGE_TYPE=local
# STORAGE_LOCAL_PATH=./data/uploads

# ----- App -----
# DEBUG=1
# SECRET_KEY=your-secret-key

# ----- ML / Try-on (optional) -----
# EMBEDDING_MODEL=
# Local try-on: path to script (human + garment -> output) or shell command with {human} {garment} {output}
# TRY_ON_SCRIPT=scripts/run_local_tryon.py   # needs: uv sync --extra tryon
# Or use IDM-VTON: TRY_ON_COMMAND="python /path/to/IDM-VTON/run_single.py --human {human} --garment {garment} --output {output}"
